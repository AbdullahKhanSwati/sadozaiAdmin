# Copy to .env and fill with your Supabase project values
# Dashboard → Settings → API

# Shots project
VITE_SUPABASE_URL=https://YOUR-SHOTS-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-shots-anon-public-key

# Munchies project (separate Supabase project)
VITE_SUPABASE_URL_MUNCHIES=https://YOUR-MUNCHIES-ref.supabase.co
VITE_SUPABASE_ANON_KEY_MUNCHIES=your-munchies-anon-public-key
